{
  "linking": {
    "ui-utilities-foundation": {
      "name": "UI Utilities Foundation",
      "role": "The Helper",
      "owner": "UI/ui_utils.c",
      "purpose": "GTK+ helpers, dialogs, validation, layouts",
      "status": "Partially complete - Dialog functions ✅, Ready: validation & widgets",
      "used-by": [
        "UI/main_window.c → Create menu dialogs, confirm actions",
        "UI/auth_form.c → Login dialogs, input validation",
        "UI/patient_form.c → Patient form layouts, field validation",
        "UI/appointment_form.c → Date/time inputs, confirmation dialogs",
        "UI/billing_form.c → Amount validation, confirmation dialogs",
        "UI/reports_form.c → Report dialogs, display formatting"
      ],
      "provides": {
        "dialog-functions": {
          "count": "6/6",
          "status": "Implemented",
          "items": {
            "show_info_dialog": "Display info message",
            "show_error_dialog": "Display error (red icon)",
            "show_confirmation_dialog": "Ask Yes/No question",
            "show_input_dialog": "Get text from user",
            "show_input_dialog_masked": "Get password (masked)",
            "show_warning_dialog": "Display warning (bonus)"
          }
        },
        "validation-functions": {
          "count": 7,
          "status": "Headers ready",
          "items": {
            "validate_phone": "Check phone format",
            "validate_email": "Check email format",
            "validate_date": "Validate YYYYMMDD",
            "validate_numeric": "Check number range",
            "validate_text_field": "Text length/chars",
            "validate_empty_field": "Required field check",
            "validate_alphanumeric": "Alphanumeric only"
          }
        },
        "widget-helpers": {
          "count": 8,
          "status": "Headers ready",
          "items": {
            "create_text_entry": "Text input field",
            "create_password_entry": "Masked input",
            "create_button": "Button with callback",
            "create_label": "Formatted labels",
            "create_combo_box": "Dropdown selection",
            "create_text_view": "Multiline editor",
            "get_entry_text": "Get field value",
            "set_entry_text": "Set field value"
          }
        },
        "layout-builders": {
          "count": 6,
          "status": "Headers ready",
          "items": {
            "create_vbox": "Vertical layout",
            "create_hbox": "Horizontal layout",
            "create_grid": "Grid layout",
            "create_form_field": "Label + widget pair",
            "create_scrolled_window": "Scrollable container",
            "set_widget_margins": "Add margins"
          }
        }
      },
      "design": "Common library shared by all UI forms - no duplication"
    },
    "authentication": {
      "name": "Authentication",
      "role": "Who Gets In?",
      "owner": "Backend/auth_manager.c",
      "purpose": "Login, sessions, roles",
      "talks-to": [
        {
          "module": "UI/auth_form.c",
          "role": "login page (TODO)"
        },
        {
          "module": "Backend/utils.c",
          "role": "password hashing"
        },
        {
          "module": "Backend/audit_logger.c",
          "role": "logs who logged in"
        },
        {
          "module": "Data/config/credentials.db",
          "role": "user accounts"
        }
      ],
      "key-functions": {
        "auth_login": "Called from UI login form",
        "auth_verify_session": "Called on UI operations",
        "auth_logout": "Called on UI logout"
      }
    },
    "patient-management": {
      "name": "Patient Management",
      "role": "The People",
      "owner": "Backend/patient_manager.c",
      "purpose": "Register, search, update, archive",
      "talks-to": [
        {
          "module": "UI/patient_form.c",
          "role": "patient dialogs (TODO)"
        },
        {
          "module": "Backend/hl7_parser.c",
          "role": "read/write HL7 format"
        },
        {
          "module": "Backend/utils.c",
          "role": "validation & file operations"
        },
        {
          "module": "Backend/audit_logger.c",
          "role": "track who changed what"
        },
        {
          "module": "Data/patients/*.seg",
          "role": "where records live"
        }
      ],
      "key-functions": [
        "patient_create() → Register new patient",
        "patient_search_by_name() → Find patient by name",
        "patient_search_by_id() → Find patient by ID",
        "patient_read() → Load full record",
        "patient_update_info() → Edit patient details"
      ],
      "data-storage": {
        "format": "HL7 segments in .seg files",
        "segments": {
          "PID": "Demographics (name, DOB, address)",
          "OBX": "Vitals & test results"
        },
        "location": "Data/patients/{patient_id}.seg"
      }
    },
    "appointment-management": {
      "name": "Appointment Management",
      "role": "The Schedule",
      "owner": "Backend/appointment_manager.c",
      "purpose": "Book, reschedule, cancel",
      "talks-to": [
        {
          "module": "UI/appointment_form.c",
          "role": "appointment dialogs (TODO)"
        },
        {
          "module": "Backend/patient_manager.c",
          "role": "Does this patient exist?"
        },
        {
          "module": "Backend/hl7_parser.c",
          "role": "read/write SCH segments"
        },
        {
          "module": "Backend/audit_logger.c",
          "role": "log scheduling changes"
        },
        {
          "module": "Data/appointments/*.seg",
          "role": "appointment records"
        }
      ],
      "key-functions": [
        "book_appointment() → Create new appointment",
        "reschedule_appointment() → Change date/time/doctor",
        "cancel_appointment() → Mark as cancelled",
        "view_appointments() → List all appointments"
      ],
      "appointment-status": ["PENDING", "CONFIRMED", "COMPLETED", "CANCELLED"],
      "data-storage": {
        "format": "HL7 Schedule (SCH) segments"
      }
    },
    "billing-invoices": {
      "name": "Billing & Invoices",
      "role": "The Money",
      "owner": "Backend/billing_manager.c",
      "purpose": "Create invoices, track payments",
      "talks-to": [
        {
          "module": "UI/billing_form.c",
          "role": "invoice dialogs (TODO)"
        },
        {
          "module": "UI/reports_form.c",
          "role": "billing reports (TODO)"
        },
        {
          "module": "Backend/patient_manager.c",
          "role": "Which patient?"
        },
        {
          "module": "Backend/hl7_parser.c",
          "role": "read/write UB1 segments"
        },
        {
          "module": "Backend/audit_logger.c",
          "role": "log payment changes"
        },
        {
          "module": "Data/backups/",
          "role": "invoice records"
        }
      ],
      "key-functions": [
        "create_invoice() → Generate new bill",
        "update_invoice_status() → Track payment progress",
        "get_invoice() → Retrieve invoice details"
      ],
      "payment-status": ["PENDING", "PARTIAL", "PAID"],
      "data-storage": {
        "format": "HL7 Billing (UB1) segments"
      }
    },
    "audit-logging": {
      "name": "Audit Logging",
      "role": "Who Did What?",
      "owner": "Backend/audit_logger.c",
      "purpose": "Silent witness to everything",
      "called-from": "Every other backend module",
      "stores-in": "Data/audit_logs/*.log",
      "viewed-by": "UI/reports_form.c (TODO)",
      "key-function": "audit_log() → Records: timestamp, username, operation, changes",
      "note": "This runs quietly in the background — everything gets logged for compliance"
    }
  },
  "file-dependency-graph": {
    "ui-layer": {
      "label": "UI Layer (What Users See)",
      "components": [
        {
          "name": "ui_utils",
          "purpose": "GTK+ library (SHARED: used by all UI forms)",
          "subcomponents": [
            "Dialog functions: 6/6 (show_info, show_error, show_confirmation, show_input, masked input)",
            "Validation ready: 7 functions",
            "Widget helpers ready: 8 functions",
            "Layout builders ready: 6 functions"
          ]
        },
        {
          "name": "main_window",
          "purpose": "Everyone's boss, talks to ALL backends"
        },
        {
          "name": "auth_form",
          "talks-to": "auth_manager"
        },
        {
          "name": "patient_form",
          "talks-to": "patient_manager"
        },
        {
          "name": "appointment_form",
          "talks-to": "appointment_manager"
        },
        {
          "name": "billing_form",
          "talks-to": "billing_manager"
        },
        {
          "name": "reports_form",
          "talks-to": "Everyone (for reports)"
        }
      ]
    },
    "backend-logic": {
      "label": "Backend Logic (The Brain)",
      "components": [
        {
          "name": "auth_manager",
          "talks-to": "utils (hash passwords)"
        },
        {
          "name": "patient_manager",
          "talks-to": "hl7_parser + utils"
        },
        {
          "name": "appointment_manager",
          "talks-to": "patient_manager + hl7_parser + utils"
        },
        {
          "name": "billing_manager",
          "talks-to": "patient_manager + hl7_parser + utils"
        },
        {
          "name": "audit_logger",
          "role": "CALLED BY ALL (silent logging)"
        }
      ]
    },
    "hl7-data": {
      "label": "HL7 Data Parser",
      "components": [
        {
          "name": "hl7_parser",
          "talks-to": "utils"
        }
      ]
    },
    "data-storage": {
      "label": "Data Storage",
      "components": [
        {
          "path": "Data/patients/*.seg",
          "owner": "patient_manager"
        },
        {
          "path": "Data/appointments/*.seg",
          "owner": "appointment_manager"
        },
        {
          "path": "Data/backups/*.seg",
          "owner": "billing_manager"
        },
        {
          "path": "Data/audit_logs/*.log",
          "owner": "audit_logger"
        },
        {
          "path": "Data/sessions/*.token",
          "owner": "auth_manager"
        },
        {
          "path": "Data/config/credentials.db",
          "owner": "auth_manager"
        }
      ]
    }
  },
  "cross-module-communication": {
    "patient-appointment-billing-chain": {
      "name": "The Patient-Appointment-Billing Chain",
      "description": "The classic workflow",
      "steps": [
        {
          "step": 1,
          "action": "Register patient",
          "call": "patient_manager.patient_create()",
          "result": "generates unique patient_id"
        },
        {
          "step": 2,
          "action": "Book appointment for patient",
          "call": "appointment_manager.book_appointment(patient_id)",
          "question": "Does patient exist?",
          "asks": "patient_manager"
        },
        {
          "step": 3,
          "action": "Create invoice after service",
          "call": "billing_manager.create_invoice(patient_id)",
          "detail": "Link charges to this patient"
        },
        {
          "step": "Final",
          "action": "Everything logged by audit_logger"
        }
      ]
    },
    "validation-chain": {
      "name": "The Validation Chain",
      "description": "Every operation goes through the same validation",
      "steps": [
        "User types something into UI",
        "Main program calls backend function",
        "utils.validate_input() checks it",
        "Operation proceeds or fails"
      ]
    }
  },
  "data-ownership": {
    "location": "Data/config/credentials.db",
    "owner": "auth_manager",
    "what": "User accounts & passwords",
    "format": "Binary DB"
  },
